# Configuracion del servidor
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/license-manager

# Telegram Bot
TELEGRAM_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Autenticacion
