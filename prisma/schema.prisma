generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TokenStatus {
  active
  expired
  suspended
  cancelled
}

model Token {
  id                   String    @id @default(cuid())
  token                String    @unique
  email                String
  name                 String
  phone                String
  createdAt            DateTime  @default(now())
  expiresAt            DateTime
  isRedeemed           Boolean   @default(false)
  redeemedAt           DateTime?
  machineId            String?
  redemptionIp         String?
  redemptionDeviceInfo String?
  redemptionTimestamp  DateTime?
  status               TokenStatus @default(active)
  statusReason         String?

  @@index([expiresAt])
  @@index([status])
  @@index([isRedeemed])
  @@map("tokens")
}
