generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TokenStatus {
  active
  expired
  suspended
  cancelled
}

model Token {
  id                   String    @id @default(cuid())
  token                String    @unique
  email                String
  name                 String
  phone                String
  createdAt            DateTime  @default(now())
  expiresAt            DateTime
  isRedeemed           Boolean   @default(false)
  redeemedAt           DateTime?
  machineId            String?
  redemptionIp         String?
  redemptionDeviceInfo String?
  redemptionTimestamp  DateTime?
  status               TokenStatus @default(active)
  statusReason         String?
  payments             Payment[]
  machines             Machine[]

  @@index([expiresAt])
  @@index([status])
  @@index([isRedeemed])
  @@map("tokens")
}

model Machine {
  id         String   @id @default(cuid())
  machineId  String
  deviceInfo String?
  ip         String?
  addedAt    DateTime @default(now())
  tokenId    String
  token      Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, machineId])
  @@index([tokenId])
  @@map("machines")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  months    Int
  paidAt    DateTime
  createdAt DateTime @default(now())
  note      String?
  tokenId   String
  token     Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
  @@index([paidAt])
  @@map("payments")
}
